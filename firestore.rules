rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: projects
    // Document ID: {projectId}
    // Fields:
    //   - id: string (required) - Unique project ID
    //   - ownerId: string (required) - UID of the project owner
    //   - name: string (optional) - Project name
    //   - data: map (required) - The full SPWData object
    //   - updatedAt: string (required) - ISO 8601 timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && 'ownerId' in resource.data && request.auth.uid == resource.data.ownerId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (request.auth.token.get('email', '') == "support@crosscloudpartners.com" && request.auth.token.get('email_verified', false) == true) ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin')
        );
    }

    function isVerified() {
      return isAuthenticated() && request.auth.token.get('email_verified', false) == true;
    }

    function hasReadPermission(projectId) {
      let userEmail = request.auth.token.email.lower();
      return isAuthenticated() && exists(/databases/$(database)/documents/projects/$(projectId)/shares/$(userEmail));
    }

    function hasEditPermission(projectId) {
      let userEmail = request.auth.token.email.lower();
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/projects/$(projectId)/shares/$(userEmail)) &&
             get(/databases/$(database)/documents/projects/$(projectId)/shares/$(userEmail)).data.permission == "edit";
    }

    function isValidProject(data) {
      return data.keys().hasAll(['id', 'ownerId', 'data', 'updatedAt']) &&
             data.id is string &&
             data.ownerId is string &&
             data.data is map &&
             data.updatedAt is string;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'firstName', 'lastName', 'email', 'companyName', 'createdAt']) &&
             data.uid is string && (data.uid == request.auth.uid || isAdmin()) &&
             data.firstName is string && data.firstName.size() <= 100 &&
             data.lastName is string && data.lastName.size() <= 100 &&
             data.email is string && data.email.size() <= 150 &&
             data.companyName is string && data.companyName.size() <= 200 &&
             data.createdAt is string && data.createdAt.size() <= 64 &&
             (!('role' in data) || data.role in ['admin', 'user']) &&
             (!('lastLogin' in data) || data.lastLogin is string);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin() || request.auth.token.get('email', '').lower() == "john.vu@crosscloudpartners.com" || request.auth.token.get('email', '').lower() == "juantvu@gmail.com";
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data) &&
                    (isAdmin() || request.resource.data.email == resource.data.email) && // email is immutable for non-admins
                    (isAdmin() || !('role' in request.resource.data) || request.resource.data.role == resource.data.role); // role is immutable for non-admins
    }

    match /projects/{projectId} {
      allow get: if isAuthenticated() && (
        resource.data.ownerId == request.auth.uid || 
        isAdmin() || 
        hasReadPermission(projectId)
      );
      allow list: if isAuthenticated() && (
        isAdmin() || 
        resource.data.ownerId == request.auth.uid
      );
      allow create: if isAuthenticated() && isValidProject(request.resource.data) && request.resource.data.ownerId == request.auth.uid;
      allow update: if (isAdmin() || resource.data.ownerId == request.auth.uid || hasEditPermission(projectId)) && 
                    isValidProject(request.resource.data) &&
                    (isAdmin() || request.resource.data.ownerId == resource.data.ownerId);
      allow delete: if isAdmin() || resource.data.ownerId == request.auth.uid;

      match /shares/{shareId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && (
          isAdmin() ||
          get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid
        );
      }
    }

    // Collection Group rules for 'shares'
    match /{path=**}/shares/{shareId} {
      allow read: if isAuthenticated();
    }

    match /activity_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }

    match /presence/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    match /settings/global {
      allow read: if isAuthenticated();
    }

    match /settings/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }
    
    match /public_profiles/{emailId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (
        request.auth.token.get('email', '').lower() == emailId || 
        isAdmin() ||
        request.auth.token.get('email', '').lower() == "john.vu@crosscloudpartners.com" ||
        request.auth.token.get('email', '').lower() == "juantvu@gmail.com"
      );
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
